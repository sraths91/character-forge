# character-forge environment variables.
# Copy to .env for local dev; Railway sets these in the service dashboard.

# Server port. Railway auto-injects this in production; the API server falls
# back to 3101 when unset (matches the Vite dev proxy in vite.config.js).
PORT=3101

# 'production' enables static serving of dist/ and disables verbose logging.
NODE_ENV=development

# Absolute path to the SQLite database. In Railway, point this at the
# mounted persistent volume so item-sprite cache survives redeploys:
#   CF_DB_PATH=/app/data/character-forge.db
# Defaults to <repo>/character-forge.db when unset.
CF_DB_PATH=
